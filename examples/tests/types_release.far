# Production regression — guards fixed compiler/runtime bugs
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
fun feq(a: f64, b: f64) -> i64 { if (a != b) { return 1 } return 0 }

fun t01_dict_get_string() -> i64 {
  d: Dict<i64, string> = Dict<i64, string>()
  d.set(1, "one")
  if (d.get(1) != "one") { return 1 }
  return 0
}

fun t02_channel_after_if_return() -> i64 {
  ch = Channel<i64>(4)
  ch.send(10)
  ch.send(20)
  if (ch.recv() != 10) { return 1 }
  return eq(ch.recv(), 20)
}

fun t03_float_ternary() -> i64 {
  return feq(1 ? 1.5 : 2.5, 1.5)
}

fun t04_f64_postinc() -> i64 {
  y: f64 = 0.0
  y++
  return feq(y, 1.0)
}

fun t05_handle_in_if_branch() -> i64 {
  if (1) {
    ch = Channel<i64>(2)
    ch.send(7)
    if (ch.recv() != 7) { return 1 }
  }
  return 0
}

fun t06_prefix_inc_stmt() -> i64 {
  x = 9
  ++x
  return eq(x, 10)
}

fun t07_ternary_paren_float() -> i64 {
  return feq((1 ? 0.5 : 1.5), 0.5)
}

fun t07b_int_float_ternary() -> i64 {
  return feq(1 ? 1 : 2.5, 1.0)
}

fun t08_prefix_f64_stmt() -> i64 {
  z: f64 = 1.5
  ++z
  return feq(z, 2.5)
}

fun t09_dict_keys_values() -> i64 {
  d: Dict<i64, string> = Dict<i64, string>()
  d.set(1, "a")
  d.set(2, "b")
  ks = d.keys()
  if (len(ks) != 2) { return 1 }
  vs = d.values()
  if (len(vs) != 2) { return 2 }
  return 0
}

fun t10_set_in_op() -> i64 {
  s: Set<i64> = Set<i64>()
  s.add(42)
  if (!(42 in s)) { return 1 }
  if (99 in s) { return 2 }
  return 0
}

fun t11_channel_autodrop() -> i64 {
  ch = Channel<i64>(1)
  ch.send(1)
  return 0
}

fun t12_null_coalesce_float() -> i64 {
  return feq(0 ?? 2.5, 2.5)
}

fun t13_f64_plus_eq() -> i64 {
  f: f64 = 1.0
  f += 2.5
  return feq(f, 3.5)
}

fun t14_f64_null_coalesce() -> i64 {
  x: f64 = 0.0
  return feq(x ?? 3.5, 3.5)
}

fun t15_f64_null_coalesce_assign() -> i64 {
  z: f64 = 0.0
  z ??= 2.5
  return feq(z, 2.5)
}

fun main() {
  r = 0
  r = run(1, t01_dict_get_string()); if (r != 0) { return r }
  r = run(2, t02_channel_after_if_return()); if (r != 0) { return r }
  r = run(3, t03_float_ternary()); if (r != 0) { return r }
  r = run(4, t04_f64_postinc()); if (r != 0) { return r }
  r = run(5, t05_handle_in_if_branch()); if (r != 0) { return r }
  r = run(6, t06_prefix_inc_stmt()); if (r != 0) { return r }
  r = run(7, t07_ternary_paren_float()); if (r != 0) { return r }
  r = run(72, t07b_int_float_ternary()); if (r != 0) { return r }
  r = run(8, t08_prefix_f64_stmt()); if (r != 0) { return r }
  r = run(9, t09_dict_keys_values()); if (r != 0) { return r }
  r = run(10, t10_set_in_op()); if (r != 0) { return r }
  r = run(11, t11_channel_autodrop()); if (r != 0) { return r }
  r = run(12, t12_null_coalesce_float()); if (r != 0) { return r }
  r = run(13, t13_f64_plus_eq()); if (r != 0) { return r }
  r = run(14, t14_f64_null_coalesce()); if (r != 0) { return r }
  r = run(15, t15_f64_null_coalesce_assign()); if (r != 0) { return r }
  print(0)
  return 0
}
