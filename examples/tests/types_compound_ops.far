# Compound assignments and increment/decrement
fun eq(a: i64, b: i64) -> i64 {
  if (a != b) { return 1 }
  return 0
}
fun run(n: i64, r: i64) -> i64 {
  if (r != 0) { print(n); return n }
  return 0
}
fun t01_plus_eq() -> i64 {
  x = 10
  x += 5
  return eq(x, 15)
}
fun t02_minus_eq() -> i64 {
  x = 20
  x -= 8
  return eq(x, 12)
}
fun t03_mul_div_mod() -> i64 {
  a = 6
  a *= 3
  a /= 2
  b = 10
  b %= 3
  return eq(a * 10 + b, 91)
}
fun t04_pow_floor() -> i64 {
  x = 2
  x **= 4
  y = 10
  y //= 3
  return eq(x + y, 19)
}
fun t05_inc_dec() -> i64 {
  i = 5
  i++
  i++
  i--
  return eq(i, 6)
}
fun t06_bitwise_eq() -> i64 {
  a = 15
  a &= 7
  a |= 8
  a ^= 1
  return eq(a, 14)
}
fun t07_shift_eq() -> i64 {
  x = 1
  x <<= 3
  x >>= 1
  return eq(x, 4)
}
fun main() {
  r = 0
  r = run(1, t01_plus_eq()); if (r != 0) { return r }
  r = run(2, t02_minus_eq()); if (r != 0) { return r }
  r = run(3, t03_mul_div_mod()); if (r != 0) { return r }
  r = run(4, t04_pow_floor()); if (r != 0) { return r }
  r = run(5, t05_inc_dec()); if (r != 0) { return r }
  r = run(6, t06_bitwise_eq()); if (r != 0) { return r }
  r = run(7, t07_shift_eq()); if (r != 0) { return r }
  print(0)
  return 0
}