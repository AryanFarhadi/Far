# Control flow: if/else, while, for, break, continue, nested logic
fun eq(a: i64, b: i64) -> i64 {
  if (a != b) { return 1 }
  return 0
}
fun run(n: i64, r: i64) -> i64 {
  if (r != 0) { print(n); return n }
  return 0
}
fun t01_if_else() -> i64 {
  x = 0
  if (true) { x = 1 } else { x = 2 }
  if (false) { x = 3 }
  return eq(x, 1)
}
fun t02_elif_chain() -> i64 {
  v = 2
  r = 0
  if (v == 1) { r = 10 }
  else if (v == 2) { r = 20 }
  else { r = 30 }
  return eq(r, 20)
}
fun t03_while_sum() -> i64 {
  i = 0
  s = 0
  while (i < 5) {
    s = s + i
    i = i + 1
  }
  return eq(s, 10)
}
fun t04_for_range() -> i64 {
  s = 0
  for i in 0..<5 {
    s = s + i
  }
  return eq(s, 10)
}
fun t05_break() -> i64 {
  s = 0
  for i in 0..<100 {
    if (i == 7) { break }
    s = s + 1
  }
  return eq(s, 7)
}
fun t06_continue() -> i64 {
  s = 0
  for i in 0..<10 {
    if (i % 2 == 0) { continue }
    s = s + i
  }
  return eq(s, 25)
}
fun t07_nested() -> i64 {
  acc = 0
  for i in 0..<3 {
    j = 0
    while (j < 2) {
      acc = acc + 1
      j = j + 1
    }
  }
  return eq(acc, 6)
}
fun t08_short_circuit() -> i64 {
  a = 0
  if (false && (a = 1) == 1) { return 1 }
  if (true || (a = 2) == 2) { }
  return eq(a, 0)
}
fun main() {
  r = 0
  r = run(1, t01_if_else()); if (r != 0) { return r }
  r = run(2, t02_elif_chain()); if (r != 0) { return r }
  r = run(3, t03_while_sum()); if (r != 0) { return r }
  r = run(4, t04_for_range()); if (r != 0) { return r }
  r = run(5, t05_break()); if (r != 0) { return r }
  r = run(6, t06_continue()); if (r != 0) { return r }
  r = run(7, t07_nested()); if (r != 0) { return r }
  r = run(8, t08_short_circuit()); if (r != 0) { return r }
  print(0)
  return 0
}