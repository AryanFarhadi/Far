# Probe batch 4 part A
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
fun t01_llist_fifo() -> i64 {
  ll: LinkedList<i64> = LinkedList<i64>()
  ll.push_back(1)
  ll.push_back(2)
  ll.push_back(3)
  if (ll.pop_front() != 1) { return 1 }
  if (ll.pop_front() != 2) { return 2 }
  return eq(ll.pop_front(), 3)
}
fun t04_range_len_step() -> i64 {
  rng = Range(0, 6, 2)
  return eq(len(rng), 3)
}
fun t06_range_for_sum() -> i64 {
  sum = 0
  for i in 0..3 {
    sum = sum + i
  }
  return eq(sum, 3)
}
fun t08_box_deref() -> i64 {
  b = Box<i64>(8)
  bp = b.get()
  unsafe { *bp = 77 }
  return eq(*bp, 77)
}
fun main() {
  r = 0
  r = run(1, t01_llist_fifo()); if (r != 0) { return r }
  r = run(4, t04_range_len_step()); if (r != 0) { return r }
  r = run(6, t06_range_for_sum()); if (r != 0) { return r }
  r = run(8, t08_box_deref()); if (r != 0) { return r }
  print(0)
  return 0
}