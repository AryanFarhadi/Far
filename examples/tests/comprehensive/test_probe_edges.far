# Probe: edge cases that often break — prints failing id or 0
import vectors
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
fun t01_string_ne_concat() -> i64 {
  a = "x" + "1"
  b = "x" + "2"
  if (!(a != b)) { return 1 }
  return 0
}
fun t02_string_eq_empty() -> i64 {
  if ("" == "") { return 0 }
  return 1
}
fun t03_dict_values() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 10)
  d.set(2, 20)
  vals = d.values()
  return eq(len(vals), 2)
}
fun t04_list_clear() -> i64 {
  lst: List<i64> = List<i64>()
  lst.push(1)
  lst.push(2)
  lst.clear()
  return eq(len(lst), 0)
}
fun t05_string_cast_loop() -> i64 {
  i = 0
  while (i < 100) {
    s = string(i)
    if (int(s) != i) { return i + 1000 }
    i = i + 1
  }
  return 0
}
fun t06_dict_string_key() -> i64 {
  d: Dict<string, i64> = Dict<string, i64>()
  k = "hel" + "lo"
  d.set(k, 42)
  if (d.get("hello") != 42) { return 1 }
  if (!d.contains_key("hello")) { return 2 }
  return 0
}
fun t07_set_string() -> i64 {
  s: Set<string> = Set<string>()
  a = "far" + "!"
  s.add(a)
  if (!s.contains("far!")) { return 1 }
  return 0
}
fun t08_vec2_length() -> i64 {
  v = dvec2(3.0, 4.0)
  if (vectors.length(v) != 5.0) { return 1 }
  return 0
}
fun main() {
  r = 0
  r = run(1, t01_string_ne_concat()); if (r != 0) { return r }
  r = run(2, t02_string_eq_empty()); if (r != 0) { return r }
  r = run(3, t03_dict_values()); if (r != 0) { return r }
  r = run(4, t04_list_clear()); if (r != 0) { return r }
  r = run(5, t05_string_cast_loop()); if (r != 0) { return r }
  r = run(6, t06_dict_string_key()); if (r != 0) { return r }
  r = run(7, t07_set_string()); if (r != 0) { return r }
  r = run(8, t08_vec2_length()); if (r != 0) { return r }
  print(0)
  return 0
}