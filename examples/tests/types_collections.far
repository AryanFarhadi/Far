# Collection types smoke test
fun main() {
  a = [1, 2, 3]
  print(len(a))
  lst: List<i64> = List<i64>()
  lst.push(1)
  print(len(lst))
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 42)
  print(d.get(1))
  s: Set<i64> = Set<i64>()
  s.add(7)
  print(s.contains(7))
  q: Queue<i64> = Queue<i64>()
  q.enqueue(1)
  print(q.dequeue())
  st: Stack<i64> = Stack<i64>()
  st.push(9)
  print(st.pop())
  ll: LinkedList<i64> = LinkedList<i64>()
  ll.push_back(2)
  ll.push_front(1)
  print(len(ll))
  print(ll.pop_front())
  t = (1, 2)
  print(t.0)
  sum = 0
  for i in 0..3 {
    sum = sum + i
  }
  print(sum)
  rng = Range(0, 6, 2)
  print(len(rng))
  sl = a.slice(1, 3)
  print(len(sl))
  return 0
}