# Union types and pattern matching
union Num {
  I(i: i64)
  B(b: i64)
}
fun eq(a: i64, b: i64) -> i64 {
  if (a != b) { return 1 }
  return 0
}
fun run(n: i64, r: i64) -> i64 {
  if (r != 0) { print(n); return n }
  return 0
}
fun t01_union_int() -> i64 {
  v = Num.I(42)
  r = 0
  match v {
    Num.I(i) => r = i
    Num.B(b) => r = -1
  }
  return eq(r, 42)
}
fun t02_union_second() -> i64 {
  v = Num.B(7)
  r = 0
  match v {
    Num.I(i) => r = 0
    Num.B(b) => r = b
  }
  return eq(r, 7)
}
fun t03_nested_match() -> i64 {
  a = Num.I(10)
  b = Num.I(20)
  s = 0
  match a {
    Num.I(x) => {
      match b {
        Num.I(y) => s = x + y
        _ => s = -1
      }
    }
    _ => s = -2
  }
  return eq(s, 30)
}
fun main() {
  r = 0
  r = run(1, t01_union_int()); if (r != 0) { return r }
  r = run(2, t02_union_second()); if (r != 0) { return r }
  r = run(3, t03_nested_match()); if (r != 0) { return r }
  print(0)
  return 0
}