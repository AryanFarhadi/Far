# Float/int literal edge cases
fun main() {
  print(0)
  print(-1)
  print(-128)
  print(42)
  print(3.14)
  print(3.14f)
  print(.5)
  print(0.0)
  print(1.0)
  print(10.0)
  print(i32(3.14f))
  print(i32(3.14))
  print(f32(42))
  print(f64(-7))
  x = 1.5
  y = 2.5f
  print(x + y)
  return 0
}