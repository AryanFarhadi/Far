# Probe batch 4 part B
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
fun t07_str_plus_eq() -> i64 {
  s = "a"
  s += "b"
  if (s != "ab") { return 1 }
  return 0
}
struct Inner { v: i64 }
struct Outer { inner: Inner }
fun t12_nested_field() -> i64 {
  o = Outer(Inner(42))
  return eq(o.inner.v, 42)
}
fun t10_arena_reset() -> i64 {
  a = Arena(256)
  p1 = a.alloc(8)
  unsafe { *p1 = i8(11) }
  a.reset()
  p2 = a.alloc(8)
  unsafe { *p2 = i8(22) }
  return eq(*p2, 22)
}
fun t11_pool_reuse() -> i64 {
  pool = Pool<i64>(2)
  o1 = pool.acquire()
  unsafe { *o1 = 99 }
  pool.release(o1)
  o2 = pool.acquire()
  return eq(*o2, 99)
}
fun main() {
  r = 0
  r = run(7, t07_str_plus_eq()); if (r != 0) { return r }
  r = run(12, t12_nested_field()); if (r != 0) { return r }
  r = run(10, t10_arena_reset()); if (r != 0) { return r }
  r = run(11, t11_pool_reuse()); if (r != 0) { return r }
  print(0)
  return 0
}