fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
fun t01_llist_fifo() -> i64 {
  ll: LinkedList<i64> = LinkedList<i64>()
  ll.push_back(1)
  ll.push_back(2)
  ll.push_back(3)
  if (ll.pop_front() != 1) { return 1 }
  if (ll.pop_front() != 2) { return 2 }
  return eq(ll.pop_front(), 3)
}
fun t07_str_plus_eq() -> i64 {
  s = "a"
  s += "b"
  if (s != "ab") { return 1 }
  return 0
}
fun main() {
  r = run(1, t01_llist_fifo()); if (r != 0) { return r }
  r = run(7, t07_str_plus_eq()); if (r != 0) { return r }
  print(0)
  return 0
}