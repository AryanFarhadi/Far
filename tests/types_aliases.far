fun main() {
  a: short = short(100)
  b: int = 200
  c: long = 300
  d: byte = byte(255)
  e: ushort = ushort(400)
  f: uint = uint(500)
  g: ulong = ulong(600)
  h: float = float(1.5f)
  i: double = 2.5
  k: str = "ok"
  if (a + b + short(c) != 600) { return 1 }
  if (d != 255) { return 2 }
  if (e + ushort(f) != 900) { return 3 }
  if (g != 600) { return 4 }
  if (int(h * double(2)) != 3) { return 5 }
  if (int(i) != 2) { return 6 }
  if (len(k) != 2) { return 7 }
  print(0)
  return 0
}
