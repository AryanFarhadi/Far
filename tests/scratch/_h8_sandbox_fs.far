import fs
import security

fun main() -> i64 {
  sandbox.open_sandbox(2)
  sandbox.allow_path("far_sandbox_ok")
  if (fs.write_text("far_sandbox_ok/data.txt", "ok") != 0) { print(1); return 1 }
  if (len(fs.read_text("far_sandbox_ok/data.txt")) != 2) { print(2); return 2 }
  if (fs.write_text("far_sandbox_denied/x.txt", "x") != -1) { print(3); return 3 }
  if (len(fs.read_text("../far_sandbox_ok/data.txt")) != 0) { print(4); return 4 }
  sandbox.close_sandbox()
  print(0)
  return 0
}
