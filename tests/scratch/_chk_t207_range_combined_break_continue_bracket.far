fun t207_range_combined_break_continue_bracket() -> i64 {
  lst: List<i64> = List<i64>()
  for x in 0..<8 {
    if (x == 3) { continue }
    if (x == 6) { break }
    lst.push(x)
  }
  lst[4] = 44
  return eq(lst.get(4), 44)
}


fun main() -> i64 { return t207_range_combined_break_continue_bracket() }
