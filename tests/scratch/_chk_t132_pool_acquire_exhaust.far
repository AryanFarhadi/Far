fun t132_pool_acquire_exhaust() -> i64 {
  pool = Pool<i64>(2)
  o1 = pool.acquire()
  o2 = pool.acquire()
  o3 = pool.acquire()
  if (o1 == 0) { return 1 }
  if (o2 == 0) { return 2 }
  if (o3 != 0) { return 3 }
  pool.release(o1)
  o4 = pool.acquire()
  if (o4 == 0) { return 4 }
  return 0
}


fun main() -> i64 { return t132_pool_acquire_exhaust() }
