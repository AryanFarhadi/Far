fun t53_dict_fuzz_permutation() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 120) {
    k = (i * 31 + 7) % 67
    d.set(k, i)
    i = i + 1
  }
  if (len(d) > 67) { return 1 }
  i = 0
  while (i < 67) {
    d.remove(i)
    if (len(d) > 67 - i - 1) { return 2 }
    i = i + 1
  }
  return eq(len(d), 0)
}


fun main() -> i64 { return t53_dict_fuzz_permutation() }
