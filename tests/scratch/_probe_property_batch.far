fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun t_dict_iter_remove() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 10); d.set(2, 20); d.set(3, 30)
  d.remove(2)
  return eq(d.get(2), 0)
}

fun t_arr_neg_runtime() -> i64 {
  a = [10, 20, 30]
  i = -1
  return eq(a[i], 0)
}

fun t_channel_send_closed() -> i64 {
  ch = Channel<i64>(1)
  ch.close()
  return eq(ch.try_send(1), -1)
}

fun t_parallel_empty() -> i64 {
  parallel for i in 0..<0 { return 1 }
  return 0
}

fun t_pow_chain() -> i64 { return eq(2 ** 3 ** 2, 512) }

fun t_mod_i64min() -> i64 { return eq((-9223372036854775808) % 7, -1) }

fun t_shl_runtime() -> i64 {
  x: i64 = 1
  y: i64 = 10
  return eq(x << y, 1024)
}

fun t_dict_size() -> i64 {
  d: Dict<i64,i64> = Dict<i64,i64>()
  d.set(1,10); d.set(2,20); d.set(1,99)
  if (len(d) != 2) { return 1 }
  return eq(d.get(1), 99)
}

fun t_set_dup() -> i64 {
  s: Set<i64> = Set<i64>()
  s.add(1); s.add(1); s.add(2)
  return eq(len(s), 2)
}

fun t_list_insert_huge() -> i64 {
  xs: List<i64> = List<i64>()
  xs.insert(999, 42)
  if (len(xs) != 1) { return 1 }
  return eq(xs[0], 42)
}

fun t_nested_break_continue() -> i64 {
  n = 0
  for i in 0..<3 {
    for j in 0..<3 {
      if (j == 1) { continue }
      if (i == 2 && j == 2) { break }
      n = n + 1
    }
  }
  return eq(n, 5)
}

fun main() -> i64 {
  r = run(1, t_dict_iter_remove()); if (r != 0) { return r }
  r = run(2, t_arr_neg_runtime()); if (r != 0) { return r }
  r = run(3, t_channel_send_closed()); if (r != 0) { return r }
  r = run(4, t_parallel_empty()); if (r != 0) { return r }
  r = run(5, t_pow_chain()); if (r != 0) { return r }
  r = run(6, t_mod_i64min()); if (r != 0) { return r }
  r = run(7, t_shl_runtime()); if (r != 0) { return r }
  r = run(8, t_dict_size()); if (r != 0) { return r }
  r = run(9, t_set_dup()); if (r != 0) { return r }
  r = run(10, t_list_insert_huge()); if (r != 0) { return r }
  r = run(11, t_nested_break_continue()); if (r != 0) { return r }
  return 0
}

fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }
