fun t223_try_continue_push_break_bracket() -> i64 {
  lst: List<i64> = List<i64>()
  for x in 0..<6 {
    try {
      if (x == 1) { continue }
      lst.push(x)
      if (x == 3) { break }
    } catch (e) {
    }
  }
  lst[2] = 22
  return eq(lst.get(2), 22)
}


fun main() -> i64 { return t223_try_continue_push_break_bracket() }
