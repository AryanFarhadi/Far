fun close_send_worker(ch: Channel<i64>) -> i64 {
  i = 0
  while (i < 50) {
    if (i == 25) { ch.close() }
    ch.try_send(99)
    i = i + 1
  }
  return 0
}

fun t42_channel_close_send_race() -> i64 {
  ch = Channel<i64>(4)
  h = spawn close_send_worker(ch)
  i = 0
  while (i < 100) {
    ch.try_send(i)
    i = i + 1
  }
  threads.join(h)
  return 0
}

fun try_finally_trace_helper(trace: List<i64>) -> i64 {
  try {
    trace.push(1)
    return 99
  } finally {
    trace.push(2)
  }
  return 0
}

fun t43_try_finally_before_return() -> i64 {
  trace: List<i64> = List<i64>()
  r = try_finally_trace_helper(trace)
  if (len(trace) != 2) { return 1 }
  if (trace[0] != 1) { return 2 }
  if (trace[1] != 2) { return 3 }
  return eq(r, 99)
}

fun t44_dict_len_insert_remove_property() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 32) {
    d.set(i, i * 10)
    if (len(d) != i + 1) { return 1 }
    i = i + 1
  }
  i = 0
  while (i < 32) {
    d.remove(i)
    if (len(d) != 31 - i) { return 2 }
    i = i + 1
  }
  return eq(len(d), 0)
}

actor StopAskCounter {
  fun on_msg(msg: i64) -> i64 { return msg + 1 }
}

fun actor_stopper(c: StopAskCounter) -> i64 {
  i = 0
  while (i < 100) {
    c.stop()
    i = i + 1
  }
  return 0
}

fun actor_asker(c: StopAskCounter) -> i64 {
  i = 0
  while (i < 100) {
    c.ask(1)
    i = i + 1
  }
  return 0
}

fun t45_actor_stop_ask_race() -> i64 {
  c = StopAskCounter()
  h1 = spawn actor_stopper(c)
  h2 = spawn actor_asker(c)
  threads.join(h1)
  threads.join(h2)
  return 0
}

fun t46_box_double_drop_safe() -> i64 {
