fun lfq_push(q: LockFreeQueue<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    if (q.push(i) == 0) {
      i = i + 1
    }
  }
  return 0
}

fun lfq_pop_sum(q: LockFreeQueue<i64>, n: i64) -> i64 {
  s = 0
  got = 0
  while (got < n) {
    v = q.pop()
    if (v >= 0) {
      s = s + v
      got = got + 1
    }
  }
  return s
}

fun inc_loop(at: Atomic<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    at.fetch_add(1)
    i = i + 1
  }
  return 0
}

fun ch_send_recv(ch: Channel<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    ch.send(i)
    i = i + 1
  }
  return 0
}

fun ch_recv_loop(ch: Channel<i64>, n: i64) -> i64 {
  got = 0
  i = 0
  while (i < n) {
    v = ch.recv()
    got = got + v
    i = i + 1
  }
  return got
}

fun mutex_holder(m: Mutex, ch: Channel<i64>) -> i64 {
  m.lock()
  ch.send(1)
  i = 0
  while (i < 500000) {
    i = i + 1
  }
  m.unlock()
  return 0
}

fun rec_depth(n: i64) -> i64 {
  if (n <= 0) { return 0 }
  return rec_depth(n - 1) + 1
}

