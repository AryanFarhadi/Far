fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun t163_while_break_continue_count() -> i64 {
  n = 0
  i = 0
  while (i < 200) {
    if (i == 100) { break }
    if (i != 50) { n = n + 1 }
    i = i + 1
  }
  return eq(n, 99)
}

fun main() -> i64 {
  return t163_while_break_continue_count()
}
