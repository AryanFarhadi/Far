fun t33_dict_insert_count_property() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 10)
  d.set(2, 20)
  d.set(3, 30)
  d.set(4, 40)
  d.set(5, 50)
  if (len(d) != 5) { return 1 }
  d.set(3, 99)
  if (len(d) != 5) { return 2 }
  return eq(d.get(3), 99)
}


fun main() -> i64 { return t33_dict_insert_count_property() }
