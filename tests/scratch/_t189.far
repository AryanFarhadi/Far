fun main() -> i64 {
  path = "far_harden_bin_test.bin"
  data = "\x00\x01\xff"
  if (fs.write_text(path, data) != 0) { return 1 }
  back = fs.read_text(path)
  if (len(back) != 3) { return 2 }
  if (back[0] != 0) { return 3 }
  if (back[1] != 1) { return 4 }
  if (back[2] != 255) { return 5 }
  fs.remove(path)
  return 0
}
