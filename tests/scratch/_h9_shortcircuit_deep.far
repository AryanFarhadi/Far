fun side(i: i64) -> i64 { return i + 1 }

fun t_deep_and_short_circuit() -> i64 {
  n = 0
  if (0 && side(1) == 2 && side(2) == 3 && side(3) == 4) { n = 1 }
  return eq(n, 0)
}

fun t_deep_or_short_circuit() -> i64 {
  n = 0
  if (1 || side(1) == 2 || side(2) == 3 || side(3) == 4) { n = 1 }
  return eq(n, 1)
}

fun main() {
  if (t_deep_and_short_circuit() != 0) { print(1); return 1 }
  if (t_deep_or_short_circuit() != 0) { print(2); return 2 }
  print(0)
  return 0
}
