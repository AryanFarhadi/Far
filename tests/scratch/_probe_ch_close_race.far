import perf
fun close_send_race() -> i64 {
  ch = Channel<i64>(4)
  h = spawn close_send_worker(ch)
  i = 0
  while (i < 100) {
    ch.try_send(i)
    i = i + 1
  }
  threads.join(h)
  return 0
}
fun close_send_worker(ch: Channel<i64>) -> i64 {
  i = 0
  while (i < 50) {
    if (i == 25) { ch.close() }
    ch.try_send(99)
    i = i + 1
  }
  return 0
}
fun main() -> i64 { return close_send_race() }
