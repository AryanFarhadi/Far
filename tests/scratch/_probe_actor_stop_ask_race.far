import perf
actor Counter {
  fun on_msg(msg: i64) -> i64 { return msg + 1 }
}
fun stopper(c: Counter) -> i64 {
  i = 0
  while (i < 200) {
    c.stop()
    i = i + 1
  }
  return 0
}
fun asker(c: Counter) -> i64 {
  i = 0
  while (i < 200) {
    c.ask(1)
    i = i + 1
  }
  return 0
}
fun main() -> i64 {
  c = Counter()
  h1 = spawn stopper(c)
  h2 = spawn asker(c)
  threads.join(h1)
  threads.join(h2)
  return 0
}
