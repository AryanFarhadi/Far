fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun inc_loop(at: Atomic<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    at.fetch_add(1)
    i = i + 1
  }
  return 0
}

fun main() -> i64 {
  at = Atomic<i64>(0)
  h1 = spawn inc_loop(at, 500)
  h2 = spawn inc_loop(at, 500)
  threads.join(h1)
  threads.join(h2)
  return eq(at.load(), 1000)
}
