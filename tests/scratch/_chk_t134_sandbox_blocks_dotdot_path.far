fun t134_sandbox_blocks_dotdot_path() -> i64 {
  sandbox.open_sandbox(2)
  sandbox.allow_path("far_harden_inner.txt")
  if (fs.write_text("far_harden_inner.txt", "ok") != 0) {
    sandbox.close_sandbox()
    return 1
  }
  if (len(fs.read_text("far_harden_inner.txt")) != 2) {
    sandbox.close_sandbox()
    fs.remove("far_harden_inner.txt")
    return 2
  }
  if (len(fs.read_text("far_harden_inner/../far_harden_inner.txt")) != 0) {
    sandbox.close_sandbox()
    fs.remove("far_harden_inner.txt")
    return 3
  }
  sandbox.close_sandbox()
  fs.remove("far_harden_inner.txt")
  return 0
}


fun main() -> i64 { return t134_sandbox_blocks_dotdot_path() }
