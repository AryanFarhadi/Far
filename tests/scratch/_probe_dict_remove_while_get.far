fun main() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 48) {
    d.set(i, i * 3)
    i = i + 1
  }
  j = 0
  s = 0
  while (j < 48) {
    s = s + d.get(j)
    d.remove(j)
    j = j + 1
  }
  if (len(d) != 0) { return 1 }
  return eq(s, 3384)
}

fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
