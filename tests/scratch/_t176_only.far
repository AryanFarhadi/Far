# Hardening pass — concurrency and cross-module edge cases
import perf
import fs
import security
import fixtures.tri_c
import vectors

fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun t176_list_push_break_set() -> i64 {
  lst: List<i64> = List<i64>()
  for (i = 0; i < 10; i = i + 1) {
    lst.push(i)
    if (i == 1) {
      break
    }
  }
  lst[1] = 9
  return eq(lst.get(1), 9)
}
fun main() -> i64 { return t176_list_push_break_set() }
