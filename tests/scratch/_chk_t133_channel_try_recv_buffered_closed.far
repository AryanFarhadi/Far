fun t133_channel_try_recv_buffered_closed() -> i64 {
  ch: Channel<i64> = Channel<i64>(2)
  ch.send(5)
  ch.send(6)
  ch.close()
  if (ch.try_recv() != 5) { return 1 }
  if (ch.try_recv() != 6) { return 2 }
  return eq(ch.try_recv(), -9223372036854775808)
}


fun main() -> i64 { return t133_channel_try_recv_buffered_closed() }
