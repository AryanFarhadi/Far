fun t212_nested_range_combined_bracket() -> i64 {
  lst: List<i64> = List<i64>()
  for i in 0..<3 {
    for x in 0..<8 {
      if (x == 3) { continue }
      if (x == 6) { break }
      lst.push(i * 10 + x)
    }
  }
  lst[14] = 99
  return eq(lst.get(14), 99)
}


fun main() -> i64 { return t212_nested_range_combined_bracket() }
