fun t66_set_fuzz_seed9973() -> i64 {
  s: Set<i64> = Set<i64>()
  i = 0
  while (i < 64) {
    s.add((i * 9973 + 41) % 127)
    if (len(s) > i + 1) { return 1 }
    i = i + 1
  }
  j = 0
  while (j < 32) {
    s.remove((j * 9973 + 41) % 127)
    j = j + 1
  }
  if (len(s) > 64) { return 2 }
  return 0
}


fun main() -> i64 { return t66_set_fuzz_seed9973() }
