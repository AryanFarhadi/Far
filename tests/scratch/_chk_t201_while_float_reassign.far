fun t201_while_float_reassign() -> i64 {
  x = 1.0
  while (x < 4.0) {
    x = x + 1.0
  }
  if (x != 4.0) {
    return 1
  }
  y: double = 2.0
  n = 0
  while (y > 0.0) {
    y = y - 1.0
    n = n + 1
  }
  if (n != 2) {
    return 2
  }
  return 0
}


fun main() -> i64 { return t201_while_float_reassign() }
