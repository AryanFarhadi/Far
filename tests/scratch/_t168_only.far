fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun t168_list_push_cstyle_for_valid_assign() -> i64 {
  lst: List<i64> = List<i64>()
  for (i = 0; i < 2; i = i + 1) {
    lst.push(i + 1)
  }
  lst[1] = 77
  return eq(lst.get(1), 77)
}

fun main() -> i64 {
  return t168_list_push_cstyle_for_valid_assign()
}
