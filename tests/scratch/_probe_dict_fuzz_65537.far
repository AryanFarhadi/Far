fun main() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 64) {
    d.set((i * 65537 + 11) % 127, i)
    if (len(d) > i + 1) { return 1 }
    i = i + 1
  }
  j = 0
  while (j < 32) {
    d.remove((j * 65537 + 11) % 127)
    j = j + 1
  }
  return eq(len(d), 32)
}

fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
