fun m1() -> i64 {
  match 2 {
    1 => return 1
    _ => return 0
  }
  return 99
}

fun m2() -> i64 {
  match 2 {
    1 => return 1
    _ => return 0
    2 => return 2
  }
  return 99
}

fun m3() -> i64 {
  match 2 {
    _ => return 0
    2 => return 2
  }
  return 99
}

fun main() -> i64 {
  print(m1())
  print(m2())
  print(m3())
  return 0
}
