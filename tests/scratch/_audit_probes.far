# Adversarial probes - flip main() return to select test
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun t_finally_throw_propagates() -> i64 {
  outer = 0
  try {
    try { throw 1 } finally { throw 2 }
  } catch (e) {
    outer = 1
  }
  return eq(outer, 1)
}

fun t_finally_return_overrides() -> i64 {
  try { throw 1 } catch (e) { return 1 } finally { return 2 }
  return 3
}

fun t_try_finally_no_catch() -> i64 {
  fin = 0
  try { throw 1 } finally { fin = 1 }
  return fin
}

fun t_defer_finally_throw() -> i64 {
  log = 0
  defer log = log + 10
  try { throw 1 } catch (e) { log = log + 1 } finally { log = log + 100 }
  return log
}

fun t_break_in_try() -> i64 {
  n = 0
  for i in 0..<5 {
    try {
      if (i == 2) { break }
      n = n + 1
    } catch (e) { n = 99 }
  }
  return eq(n, 2)
}

fun t_continue_in_try() -> i64 {
  n = 0
  for i in 0..<5 {
    try {
      if (i == 2) { continue }
      n = n + 1
    } catch (e) { n = 99 }
  }
  return eq(n, 4)
}

fun t_u64_eq_zero() -> i64 {
  x: u64 = 0
  if (x == 0) { return 0 }
  return 1
}

fun t_i64_eq_u64_zero() -> i64 {
  y: u64 = 0
  if (0 == y) { return 0 }
  return 1
}

fun t_shift_zero() -> i64 {
  return eq(5 >> 0, 5)
}

fun t_empty_array_len() -> i64 {
  return eq(len([]), 0)
}

fun t_string_eq_empty() -> i64 {
  a = ""
  b = ""
  if (a == b) { return 0 }
  return 1
}

fun main() -> i64 {
  return t_finally_throw_propagates()
}
