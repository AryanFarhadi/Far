fun main() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 50) {
    d.set(i, i * 10)
    i = i + 1
  }
  j = 0
  while (j < 50) {
    d.remove(j)
    if (len(d) != 50 - j - 1) { return 1 }
    j = j + 1
  }
  k = 0
  while (k < 50) {
    d.set(k, k)
    if (len(d) != k + 1) { return 2 }
    k = k + 1
  }
  return 0
}
