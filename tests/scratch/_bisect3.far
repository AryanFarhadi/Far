# Hardening pass — concurrency and cross-module edge cases
import perf
import fs
import security
import fixtures.tri_c
import vectors

fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun run(id: i64, r: i64) -> i64 { if (r != 0) { print(id); return id } return 0 }

fun inc_loop(at: Atomic<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    at.fetch_add(1)
    i = i + 1
  }
  return 0
}

fun t01_atomic_fetch_add_race() -> i64 {
  at = Atomic<i64>(0)
  h1 = spawn inc_loop(at, 500)
  h2 = spawn inc_loop(at, 500)
  threads.join(h1)
  threads.join(h2)
  return eq(at.load(), 1000)
}

fun t02_dict_tombstone_reinsert() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 32) {
    d.set(i, i)
    i = i + 1
  }
  i = 0
  while (i < 16) {
    d.remove(i)
    i = i + 1
  }
  d.set(99, 990)
  return eq(d.get(99), 990)
}

fun t03_forin_shrink_no_oob() -> i64 {
  lst: List<i64> = List<i64>()
  lst.push(1)
  lst.push(2)
  lst.push(3)
  n = 0
  for x in lst {
    n = n + x
    if (x == 2) { lst.remove(1) }
  }
  return eq(n, 3)
}

fun t04_forin_grow_bounded() -> i64 {
  lst: List<i64> = List<i64>()
  lst.push(1)
  lst.push(2)
  n = 0
  for x in lst {
    n = n + 1
    if (n == 2) { break }
    lst.push(99)
  }
  return eq(n, 2)
}

fun ch_send_recv(ch: Channel<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    ch.send(i)
    i = i + 1
  }
  return 0
}

fun ch_recv_loop(ch: Channel<i64>, n: i64) -> i64 {
  got = 0
  i = 0
  while (i < n) {
    v = ch.recv()
    got = got + v
    i = i + 1
  }
  return got
}

fun t05_channel_send_recv_race() -> i64 {
  ch = Channel<i64>(8)
  h1 = spawn ch_send_recv(ch, 50)
  h2 = spawn ch_recv_loop(ch, 50)
  threads.join(h1)
  s = threads.join(h2)
  return eq(s, 1225)
}

fun t06_lfq_push_pop_race() -> i64 {
  q = LockFreeQueue<i64>(16)
  h1 = spawn lfq_push(q, 100)
  h2 = spawn lfq_pop_sum(q, 100)
  threads.join(h1)
  s = threads.join(h2)
  return eq(s, 4950)
}

fun t07_forin_slice_sum() -> i64 {
  a = [1, 2, 3, 4, 5]
  s = a.slice(1, 4)
  n = 0
  for x in s {
    n = n + x
  }
  return eq(n, 9)
}

fun t08_set_remove_all_readd() -> i64 {
  st: Set<i64> = Set<i64>()
  i = 0
  while (i < 8) {
    st.add(i)
    i = i + 1
  }
  i = 0
  while (i < 8) {
    st.remove(i)
    i = i + 1
  }
  st.add(42)
  return eq(st.contains(42), 1)
}

fun t09_sandbox_fs_allow_deny() -> i64 {
  sandbox.open_sandbox(2)
  sandbox.allow_path("far_harden_sandbox.txt")
  if (fs.write_text("far_harden_sandbox.txt", "ok") != 0) { return 1 }
  if (len(fs.read_text("far_harden_sandbox.txt")) != 2) { return 2 }
  if (fs.write_text("far_harden_denied.txt", "x") != -1) { return 3 }
  sandbox.close_sandbox()
  fs.remove("far_harden_sandbox.txt")
  return 0
}

fun t10_dict_duplicate_key() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 10)
  d.set(1, 20)
  if (len(d) != 1) { return 1 }
  return eq(d.get(1), 20)
}

fun t11_semaphore_try_wait() -> i64 {
  sem = Semaphore(0)
  if (sem.try_wait() != 0) { return 1 }
  sem.signal()
  if (sem.try_wait() != 1) { return 2 }
  if (sem.try_wait() != 0) { return 3 }
  return 0
}

fun t12_deep_short_circuit() -> i64 {
  n = 0
  if (0 && (n = 1) != 0 && (n = 2) != 0) { return 1 }
  if (n != 0) { return 2 }
  x = 0
  if (1 || (x = 1) != 0) { }
  return eq(x, 0)
}

fun mutex_holder(m: Mutex, ch: Channel<i64>) -> i64 {
  m.lock()
  ch.send(1)
  i = 0
  while (i < 500000) {
    i = i + 1
  }
  m.unlock()
  return 0
}

fun t13_mutex_cross_thread_block() -> i64 {
  m = Mutex()
  ch = Channel<i64>(1)
  h = spawn mutex_holder(m, ch)
  ch.recv()
  m.lock()
  m.unlock()
  threads.join(h)
  return 0
}

fun rec_depth(n: i64) -> i64 {
  if (n <= 0) { return 0 }
  return rec_depth(n - 1) + 1
}

fun t14_recursion_depth_1000() -> i64 {
  return eq(rec_depth(1000), 1000)
}

fun t15_list_insert_huge_index() -> i64 {
  xs: List<i64> = List<i64>()
  xs.insert(999, 42)
  if (len(xs) != 1) { return 1 }
  return eq(xs[0], 42)
}

fun t16_parallel_for_zero_iters() -> i64 {
  parallel for i in 0..<0 { return 1 }
  return 0
}

fun t17_dict_bracket_missing_key() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  return eq(d[99], 0)
}

fun with_default(x: i64, y: i64 = 99) -> i64 {
  return x + y
}

fun t18_default_param_skipped() -> i64 {
  if (with_default(1, 2) != 3) { return 1 }
  return eq(with_default(5), 104)
}

fun t19_dict_extreme_keys() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(-9223372036854775808, 42)
  d.set(9223372036854775807, 99)
  if (d.get(-9223372036854775808) != 42) { return 1 }
  return eq(d.get(9223372036854775807), 99)
}

fun t20_dict_bracket_assign() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d[7] = 42
  if (len(d) != 1) { return 1 }
  d[7] = 100
  return eq(d.get(7), 100)
}


fun main() { return 0 }
