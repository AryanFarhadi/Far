fun t211_cstyle_push_continue_before_break_bracket() -> i64 {
  lst: List<i64> = List<i64>()
  for (x = 0; x < 6; x = x + 1) {
    if (x == 1) { continue }
    lst.push(x)
    if (x == 3) { break }
  }
  lst[2] = 22
  return eq(lst.get(2), 22)
}


fun main() -> i64 { return t211_cstyle_push_continue_before_break_bracket() }
