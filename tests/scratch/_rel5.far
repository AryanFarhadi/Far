fun t55_rle_roundtrip() -> i64 {
  raw = "aaabbc"
  enc = compress.rle_encode(raw)
  dec = compress.rle_decode(enc)
  if (len(dec) != len(raw)) { return 1 }
  if (dec != raw) { return 2 }
  return 0
}

