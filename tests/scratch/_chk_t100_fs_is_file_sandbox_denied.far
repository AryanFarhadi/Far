fun t100_fs_is_file_sandbox_denied() -> i64 {
  if (fs.write_text("far_harden_outside.txt", "x") != 0) { return 1 }
  sandbox.open_sandbox(2)
  sandbox.allow_path("far_harden_inside.txt")
  if (fs.is_file("far_harden_outside.txt")) { return 2 }
  if (fs.is_dir("far_harden_outside.txt")) { return 3 }
  sandbox.close_sandbox()
  fs.remove("far_harden_outside.txt")
  return 0
}


fun main() -> i64 { return t100_fs_is_file_sandbox_denied() }
