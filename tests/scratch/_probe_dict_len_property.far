fun dict_len_property() -> i64 {
  d: Dict<i64,i64> = Dict<i64,i64>()
  i = 0
  while (i < 32) {
    d.set(i, i * 10)
    if (len(d) != i + 1) { return 1 }
    i = i + 1
  }
  i = 0
  while (i < 32) {
    d.remove(i)
    if (len(d) != 31 - i) { return 2 }
    i = i + 1
  }
  return eq(len(d), 0)
}
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
fun main() -> i64 { return dict_len_property() }
