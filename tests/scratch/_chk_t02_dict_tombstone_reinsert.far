fun t02_dict_tombstone_reinsert() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 32) {
    d.set(i, i)
    i = i + 1
  }
  i = 0
  while (i < 16) {
    d.remove(i)
    i = i + 1
  }
  d.set(99, 990)
  return eq(d.get(99), 990)
}


fun main() -> i64 { return t02_dict_tombstone_reinsert() }
