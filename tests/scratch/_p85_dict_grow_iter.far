fun main() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  d.set(1, 10)
  d.set(2, 20)
  n = 0
  ks = d.keys()
  i = 0
  while (i < len(ks)) {
    k = ks.get(i)
    n = n + k
    d.set(99, 99)
    i = i + 1
  }
  return eq(n, 3)
}
fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }
