fun t64_dict_fuzz_seed7919() -> i64 {
  d: Dict<i64, i64> = Dict<i64, i64>()
  i = 0
  while (i < 80) {
    k = (i * 7919 + 13) % 97
    d.set(k, i)
    i = i + 1
  }
  if (len(d) > 97) { return 1 }
  j = 0
  while (j < 40) {
    rk = (j * 7919 + 13) % 97
    d.remove(rk)
    j = j + 1
  }
  if (len(d) > 57) { return 2 }
  return 0
}


fun main() -> i64 { return t64_dict_fuzz_seed7919() }
