fun t114_set_fuzz_seed48271() -> i64 {
  s: Set<i64> = Set<i64>()
  i = 0
  while (i < 96) {
    s.add((i * 48271 + 29) % 149)
    if (len(s) > i + 1) { return 1 }
    i = i + 1
  }
  j = 0
  while (j < 48) {
    s.remove((j * 48271 + 29) % 149)
    j = j + 1
  }
  return eq(len(s), 48)
}


fun main() -> i64 { return t114_set_fuzz_seed48271() }
