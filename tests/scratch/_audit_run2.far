fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun t_throw_finally_outer_catch() -> i64 {
  outer = 0
  try { try { throw 1 } finally { throw 2 } } catch (e) { outer = 1 }
  return eq(outer, 1)
}

fun t_return_in_catch_finally() -> i64 {
  try { throw 1 } catch (e) { return 2 } finally { return 3 }
  return 4
}

fun t_break_in_try_finally() -> i64 {
  n = 0
  for i in 0..<5 {
    try {
      if (i == 2) { break }
      n = n + 1
    } finally { n = n + 10 }
  }
  return eq(n, 12)
}

fun t_nested_finally_order() -> i64 {
  log = 0
  try {
    try { throw 1 } catch (e) { log = log + 1 } finally { log = log + 10 }
  } finally { log = log + 100 }
  return eq(log, 111)
}

fun t_slice_clamped() -> i64 {
  a = [10, 20, 30]
  s = a[1..2]
  return eq(len(s), 1)
}

fun t_empty_slice() -> i64 {
  a = [1, 2, 3]
  s = a[2..2]
  return eq(len(s), 0)
}

fun t_neg_index_array() -> i64 {
  a = [5, 6, 7]
  return a[-1]
}

fun t_string_null_byte() -> i64 {
  s = "a\0b"
  return len(s)
}

fun t_and_or_prec() -> i64 {
  if (0 && 1 | 2) { return 1 }
  return 0
}

fun t_shift_rhs_64() -> i64 {
  return 1 << 64
}

fun main() -> i64 { return t_shift_rhs_64() }
