fun t71_list_remove_value() -> i64 {
  lst: List<i64> = List<i64>()
  lst.push(10)
  lst.push(20)
  lst.push(30)
  if (lst.remove_value(20) != 1) { return 1 }
  if (len(lst) != 2) { return 2 }
  if (lst.get(0) != 10) { return 3 }
  if (lst.get(1) != 30) { return 4 }
  if (lst.remove_value(99) != 0) { return 5 }
  return 0
}


fun main() -> i64 { return t71_list_remove_value() }
