import fs

fun eq(a: i64, b: i64) -> i64 { if (a != b) { return 1 } return 0 }

fun main() -> i64 {
  if (len(fs.read_text("far_oversize_read_test.bin")) != 0) { return 1 }
  if (eq(len(fs.read_text("far_fs_max_read_test.bin")), 67108864) != 0) { return 2 }
  data = fs.read_text("far_fs_max_read_test.bin")
  if (fs.write_text("far_fs_roundtrip_test.bin", data) != 0) { return 3 }
  if (eq(len(fs.read_text("far_fs_roundtrip_test.bin")), 67108864) != 0) { return 4 }
  return 0
}
