# Security: memory safety, bounds, overflow, concurrency, permissions, sandbox, crypto
import security
fun test_memory() -> i64 {
  g = memsafe.make_guard(64)
  if (g <= 0) { return 1 }
  if (memsafe.is_valid(g) != 1) { return 2 }
  if (memsafe.guarded_size(g) != 64) { return 3 }
  if (memsafe.wipe(g) != 0) { return 4 }
  if (memsafe.is_valid(g) != 0) { return 5 }
  return 0
}
fun test_bounds() -> i64 {
  if (boundscheck.index_ok(2, 5) != 1) { return 10 }
  if (boundscheck.index_ok(5, 5) != 0) { return 11 }
  if (boundscheck.slice_ok(1, 3, 5) != 1) { return 12 }
  if (boundscheck.slice_ok(3, 3, 5) != 0) { return 13 }
  if (boundscheck.clamp_index(9, 5) != 4) { return 14 }
  if (boundscheck.slice_ok(0, 9223372036854775807, 10) != 0) { return 15 }
  return 0
}
fun test_overflow() -> i64 {
  v = overflow.add_safe(100, 200)
  if (v != 300) { return 20 }
  if (overflow.overflowed() != 0) { return 21 }
  v2 = overflow.mul_safe(1000, 1000)
  if (v2 != 1000000) { return 22 }
  v3 = overflow.add_safe(9223372036854775807, 1)
  if (overflow.overflowed() != 1) { return 23 }
  v4 = overflow.sub_safe(10, 3)
  if (v4 != 7) { return 24 }
  return 0
}
fun test_concurrency() -> i64 {
  if (concurrency.try_acquire(1) != 1) { return 30 }
  if (concurrency.is_owned(1) != 1) { return 31 }
  if (concurrency.try_acquire(1) != 0) { return 32 }
  if (concurrency.release(1) != 1) { return 33 }
  if (concurrency.is_owned(1) != 0) { return 34 }
  return 0
}
fun test_permission() -> i64 {
  principal = 42
  read_bit = 1
  write_bit = 2
  if (permission.grant(principal, read_bit) != 1) { return 40 }
  if (permission.has_perm(principal, read_bit) != 1) { return 41 }
  if (permission.grant(principal, write_bit) != 3) { return 42 }
  if (permission.revoke(principal, read_bit) != 2) { return 43 }
  if (permission.bits(principal) != 2) { return 44 }
  return 0
}
fun test_sandbox() -> i64 {
  if (sandbox.is_active() != 0) { return 50 }
  if (sandbox.open_sandbox(2) != 2) { return 51 }
  if (sandbox.is_active() != 1) { return 52 }
  if (sandbox.allow_path("examples") != 1) { return 53 }
  if (sandbox.can_access("examples/tests") != 1) { return 54 }
  if (sandbox.can_access("forbidden") != 0) { return 55 }
  if (sandbox.close_sandbox() != 0) { return 56 }
  if (sandbox.is_active() != 0) { return 57 }
  return 0
}
fun test_crypto() -> i64 {
  d = crypto.digest("far")
  if (len(d) != 32) { return 60 }
  plain = "far"
  enc = crypto.encrypt(plain, "key")
  if (len(enc) != 3) { return 61 }
  dec = crypto.encrypt(enc, "key")
  if (len(dec) != 3) { return 62 }
  if (crypto.secure_eq(d, d) != 1) { return 63 }
  if (crypto.secure_eq(plain, dec) != 1) { return 64 }
  t = crypto.token(8)
  if (len(t) != 16) { return 65 }
  return 0
}
fun main() -> i64 {
  r = test_memory()
  if (r != 0) { return r }
  r = test_bounds()
  if (r != 0) { return r }
  r = test_overflow()
  if (r != 0) { return r }
  r = test_concurrency()
  if (r != 0) { return r }
  r = test_permission()
  if (r != 0) { return r }
  r = test_sandbox()
  if (r != 0) { return r }
  r = test_crypto()
  if (r != 0) { return r }
  return 0
}