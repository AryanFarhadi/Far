# Standard library imports
import hash
import json
import math
fun eq(a: i64, b: i64) -> i64 {
  if (a != b) { return 1 }
  return 0
}
fun run(n: i64, r: i64) -> i64 {
  if (r != 0) { print(n); return n }
  return 0
}
fun t01_math() -> i64 {
  if (math.clamp(5, 0, 10) != 5) { return 1 }
  if (math.imin(3, 7) != 3) { return 2 }
  if (math.imax(3, 7) != 7) { return 3 }
  return 0
}
fun t02_hash() -> i64 {
  h = hash.fnv("test")
  if (h == 0) { return 1 }
  return 0
}
fun t03_json() -> i64 {
  s = json.stringify_i64(12345)
  if (len(s) != 5) { return 1 }
  if (int(s) != 12345) { return 2 }
  return 0
}
fun main() {
  r = 0
  r = run(1, t01_math()); if (r != 0) { return r }
  r = run(2, t02_hash()); if (r != 0) { return r }
  r = run(3, t03_json()); if (r != 0) { return r }
  print(0)
  return 0
}