# Float literals, casts, and arithmetic
fun add_f(a: f64, b: f64) -> f64 {
  return a + b
}
fun mul_i_to_d(x: i32, y: i32) -> f64 {
  return f64(x) * f64(y)
}
fun feq(a: f64, b: f64) -> i64 {
  if (a != b) { return 1 }
  return 0
}
fun main() {  print(3.14)
  print(.5)
  print(0.0)
  print(1.0)
  print(10.0 / 4.0)
  print(3.0 / 2.0)
  print(3 / 2.0)
  print(f32(3))
  print(f64(7))
  print(i32(3.7))
  print(i32(3.2))
  print(add_f(1.5, 2.5))
  print(mul_i_to_d(6, 7))
  print(f64(3) / f64(2))
  print(i32(f64(3) / f64(2)))
  print(i32(f64(10) / f64(3)))
  x = 2.5
  print(x + 1.5)
  print(x * 2.0)
  t = 1 ? 1.5 : 2.5
  print(t)
  if (feq(t, 1.5) != 0) { return 1 }
  y: f64 = 0.0
  y++
  print(y)
  if (feq(y, 1.0) != 0) { return 2 }
  if (0.0 / 0.0 == 0.0 / 0.0) { return 3 }
  z: f64 = 0.0
  if (z / z == z / z) { return 4 }
  return 0
}