fun lfq_push(q: LockFreeQueue<i64>, n: i64) -> i64 {
  i = 0
  while (i < n) {
    if (q.push(i) == 0) {
      i = i + 1
    }
  }
  return 0
}

fun lfq_pop_sum(q: LockFreeQueue<i64>, n: i64) -> i64 {
  s = 0
  got = 0
  while (got < n) {
    v = q.pop()
    if (v >= 0) {
      s = s + v
      got = got + 1
    }
  }
  return s
}

