class Counter {
  public n: i64 = 0
  public Counter(start: i64) { n = start }
  public fun bump() -> i64 { n = n + 1; return n }
}

fun with_ctr_default(ctr: Counter, x: i64 = ctr.bump()) -> i64 {
  return x
}

fun t24_default_param_side_effect() -> i64 {
  ctr = Counter(0)
  if (with_ctr_default(ctr) != 1) { return 1 }
  if (with_ctr_default(ctr) != 2) { return 2 }
  return eq(with_ctr_default(ctr, 99), 99)
}

fun sum_all(...nums) -> i64 {
  total = 0
  for i in 0..<len(nums) {
    total = total + nums[i]
  }
  return total
}

fun t25_varargs_empty_and_multi() -> i64 {
  if (sum_all() != 0) { return 1 }
  return eq(sum_all(1, 2, 3), 6)
}

fun t26_match_f64_nan_wildcard() -> i64 {
