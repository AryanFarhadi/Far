  r = run(5, t05_channel_send_recv_race()); if (r != 0) { return r }
  r = run(6, t06_lfq_push_pop_race()); if (r != 0) { return r }
  r = run(7, t07_forin_slice_sum()); if (r != 0) { return r }
  r = run(8, t08_set_remove_all_readd()); if (r != 0) { return r }
  r = run(9, t09_sandbox_fs_allow_deny()); if (r != 0) { return r }
  r = run(10, t10_dict_duplicate_key()); if (r != 0) { return r }
  r = run(11, t11_semaphore_try_wait()); if (r != 0) { return r }
