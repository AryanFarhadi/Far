  r = 0
  r = run(1, t01_atomic_fetch_add_race()); if (r != 0) { return r }
  r = run(2, t02_dict_tombstone_reinsert()); if (r != 0) { return r }
  r = run(3, t03_forin_shrink_no_oob()); if (r != 0) { return r }
