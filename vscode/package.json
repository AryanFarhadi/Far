{
  "name": "far-lang",
  "displayName": "Far Language",
  "description": "Far language support: scoped IntelliSense, signature help, go-to-fun, live diagnostics, format",
  "version": "0.3.21",
  "publisher": "far",
  "license": "MIT",
  "icon": "icons/far-light.svg",
  "repository": {
    "type": "git",
    "url": "https://github.com/far-lang/far"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Debuggers"],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:far",
    "workspaceContains:**/*.far"
  ],
  "contributes": {
    "languages": [
      {
        "id": "far",
        "aliases": ["Far", "far"],
        "extensions": [".far"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/far-light.svg",
          "dark": "./icons/far-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "far",
        "scopeName": "source.far",
        "path": "./syntaxes/far.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Far Syntax (Dark)",
        "uiTheme": "vs-dark",
        "path": "./themes/far-syntax-color-theme.json"
      }
    ],
    "snippets": [
      {
        "language": "far",
        "path": "./snippets/far.json"
      }
    ],
    "commands": [
      {
        "command": "far.runFile",
        "title": "Far: Run File",
        "icon": "$(play)"
      },
      {
        "command": "far.checkFile",
        "title": "Far: Check File"
      },
      {
        "command": "far.buildFile",
        "title": "Far: Build File"
      },
      {
        "command": "far.setup",
        "title": "Far: Setup Compiler"
      },
      {
        "command": "far.refreshIntelliSense",
        "title": "Far: Refresh IntelliSense from Core"
      },
      {
        "command": "far.formatFile",
        "title": "Far: Format File"
      },
      {
        "command": "far.registerWindowsFileType",
        "title": "Far: Register Windows .far File Icon"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "far.runFile",
          "when": "resourceLangId == far",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "far.runFile",
          "when": "resourceLangId == far",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "far.runFile",
          "when": "resourceLangId == far"
        },
        {
          "command": "far.checkFile",
          "when": "resourceLangId == far"
        },
        {
          "command": "far.buildFile",
          "when": "resourceLangId == far"
        }
      ]
    },
    "configurationDefaults": {
      "files.associations": {
        "*.far": "far"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          { "scope": "source.far comment.line.number-sign.far", "settings": { "foreground": "#7A8B7E", "fontStyle": "italic" } },
          { "scope": "source.far string.quoted.double.far, source.far string.quoted.single.far, source.far string.interpolated.far", "settings": { "foreground": "#F4BF9A" } },
          { "scope": "source.far constant.numeric.far, source.far constant.numeric.hex.far, source.far constant.numeric.binary.far", "settings": { "foreground": "#A8E6A0" } },
          { "scope": "source.far constant.language.far", "settings": { "foreground": "#C792EA" } },
          { "scope": "source.far keyword.control.far", "settings": { "foreground": "#C792EA" } },
          { "scope": "source.far keyword.control.import.far", "settings": { "foreground": "#C792EA" } },
          { "scope": "source.far keyword.declaration.far", "settings": { "foreground": "#C792EA" } },
          { "scope": "source.far storage.modifier.far", "settings": { "foreground": "#B794F6" } },
          { "scope": "source.far storage.type.far", "settings": { "foreground": "#7DD3FC" } },
          { "scope": "source.far entity.name.type.far", "settings": { "foreground": "#7DD3FC" } },
          { "scope": "source.far support.function.io.far", "settings": { "foreground": "#FF9F43" } },
          { "scope": "source.far support.function.builtin.far", "settings": { "foreground": "#FF9F43" } },
          { "scope": "source.far entity.name.function.far, source.far entity.name.function.call.far, source.far entity.name.function.member.far", "settings": { "foreground": "#FF9F43" } },
          { "scope": "source.far variable.other.readwrite.far, source.far variable.other.assignment.far, source.far variable.other.index.far, source.far variable.other.slice.far", "settings": { "foreground": "#9CDCFE" } },
          { "scope": "source.far variable.parameter.far", "settings": { "foreground": "#9CDCFE", "fontStyle": "italic" } },
          { "scope": "source.far variable.other.member.far", "settings": { "foreground": "#9CDCFE" } },
          { "scope": "source.far variable.other.import.far", "settings": { "foreground": "#9CDCFE" } },
          { "scope": "source.far entity.name.namespace.far", "settings": { "foreground": "#7DD3FC" } },
          { "scope": "source.far keyword.operator.slice.far, source.far keyword.operator.range.far", "settings": { "foreground": "#FF9F43" } },
          { "scope": "source.far keyword.operator.arrow.far", "settings": { "foreground": "#C792EA" } },
          { "scope": "source.far keyword.operator.comparison.far, source.far keyword.operator.logical.far, source.far keyword.operator.bitwise.far", "settings": { "foreground": "#B794F6" } },
          { "scope": "source.far keyword.operator.assignment.far, source.far keyword.operator.far", "settings": { "foreground": "#D4BFFF" } },
          { "scope": "source.far punctuation.section.slice.begin.far, source.far punctuation.section.slice.end.far, source.far punctuation.section.index.begin.far, source.far punctuation.section.index.end.far", "settings": { "foreground": "#D4BFFF" } },
          { "scope": "source.far punctuation.definition.block.far, source.far punctuation.definition.parameters.far", "settings": { "foreground": "#D4BFFF" } },
          { "scope": "source.far punctuation.separator.far, source.far punctuation.accessor.far", "settings": { "foreground": "#A0A0B0" } },
          { "scope": "source.far entity.other.attribute-name.far", "settings": { "foreground": "#F6D365" } }
        ]
      },
      "[far]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnSave": false,
        "editor.fontFamily": "'Cascadia Code', 'Segoe UI Variable', 'Segoe UI', 'JetBrains Mono', 'Fira Code', Consolas, monospace",
        "editor.fontWeight": "normal",
        "editor.fontLigatures": true,
        "editor.wordBasedSuggestions": "off",
        "editor.suggest.showWords": false,
        "editor.suggest.showSnippets": true,
        "editor.suggest.localityBonus": true,
        "editor.suggestOnTriggerCharacters": true,
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": true
        }
      }
    },
    "configuration": {
      "title": "Far",
      "properties": {
        "far.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to far.exe (leave empty to auto-detect in workspace or PATH)."
        },
        "far.clangPath": {
          "type": "string",
          "default": "clang",
          "description": "Clang executable used by the Far compiler backend."
        },
        "far.corePath": {
          "type": "string",
          "default": "",
          "description": "Path to the language core/ folder. Used to auto-refresh IntelliSense when core modules change."
        },
        "far.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run far check on save and show diagnostics."
        },
        "far.checkWhileTyping": {
          "type": "boolean",
          "default": true,
          "description": "Run far check while typing (debounced) for live error squiggles."
        },
        "far.checkDebounceMs": {
          "type": "integer",
          "default": 400,
          "minimum": 100,
          "maximum": 5000,
          "description": "Milliseconds to wait after typing before running far check."
        },
        "far.runInTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Run programs in the integrated terminal (recommended)."
        },
        "far.autoStdlibCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Suggest all stdlib functions automatically (from core-api.json). New stdlib methods appear after running generate-core-api or rebuilding the extension."
        },
        "far.stdlibCompletionMinPrefix": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 4,
          "description": "Minimum typed characters before showing full stdlib catalog (0 = show all on Ctrl+Space)."
        },
        "far.registerWindowsFileType": {
          "type": "boolean",
          "default": true,
          "description": "Register .far files in Windows Explorer with the orange Far icon (Windows only)."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "far",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Far source file to run"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "far",
        "owner": "far",
        "fileLocation": ["absolute"],
        "pattern": [
          {
            "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          },
          {
            "regexp": "^(?:error: )?line (\\d+):(\\d+): (.*)$",
            "line": 1,
            "column": 2,
            "message": 3
          },
          {
            "regexp": "^error: (.*)$",
            "message": 1
          }
        ]
      }
    ]
  }
}
