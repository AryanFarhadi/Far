import bench

# Default: 8_000_000 (match BENCH_COLLATZ_LIMIT)

fun collatz_sum() -> u64 {
  limit: i64 = 8000000
  sum: i64 = 0
  i: i64 = 1
  while (i <= limit) {
    x = u64(i)
    while (x != 1) {
      if (x % 2 == 1) {
        x = x * 3 + 1
      } else {
        x = x / 2
      }
      sum = sum + 1
    }
    i = i + 1
  }
  return u64(sum)
}

fun main() -> i64 {
  t0 = bench.start()
  r = collatz_sum()
  ms = bench.elapsed_ms(t0)
  print(ms)
  print(i64(r))
  return 0
}
